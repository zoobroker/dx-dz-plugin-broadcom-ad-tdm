{
  "name": "dx-dz-plugin-broadcom-ad-tdm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "libs/*"
  ],
  "nx": {
    "includedScripts": []
  },
  "scripts": {
    "build": "bunx nx run-many -t build",
    "test": "bunx nx run-many -t test",
    "test:watch": "bunx nx run-many -t test --watch",
    "lint": "bunx nx run-many -t lint",
    "lint:fix": "bunx nx run-many -t lint --fix",
    "typecheck": "bunx nx run-many -t typecheck",
    "prebuild": "bun tools/prebuild-audit.mjs",
    "scripts:lint": "bun tools/lint-scripts.mjs",
    "plugins:hash": "bun tools/plugins-hash.mjs",
    "plugins:bump": "bun tools/plugins-bump.mjs",
    "plugins:verify": "bun tools/plugins-verify.mjs",
    "package:release": "bun tools/package-release.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "fflate": "^0.8.2",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@nx/eslint": "22.7.2",
    "@nx/eslint-plugin": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/vitest": "22.7.2",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.14.0",
    "husky": "^9.0.0",
    "nx": "22.7.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "form-data": ">=4.0.6",
    "tmp": ">=0.2.6",
    "yaml": ">=2.8.3",
    "axios": ">=1.18.0",
    "brace-expansion": "^2.0.2"
  }
}
